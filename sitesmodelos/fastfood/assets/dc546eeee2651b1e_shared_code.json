=\"p-2 border border-white/10 rounded hover:bg-white/5 text-white\"><span class=\"iconify\" data-icon=\"lucide:arrow-right\"></span></button>\n                </div>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n                <!-- Card 1 -->\n                <div class=\"group bg-[#151515] rounded-xl overflow-hidden border border-white/5 hover:border-orange-500/50 transition-all duration-300 relative\">\n                    <div class=\"absolute top-4 right-4 bg-orange-600 text-white text-xs font-heading font-bold px-3 py-1 rounded z-10\">BEST-SELLER</div>\n                    <div class=\"h-64 overflow-hidden relative\">\n                        <img src=\"https://images.unsplash.com/photo-1594212699903-ec8a3eca50f5?q=80&amp;w=800&amp;auto=format&amp;fit=crop\" alt=\"Menu Bledar\" class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-110\">\n                        <div class=\"absolute inset-0 bg-gradient-to-t from-[#151515] to-transparent\"></div>\n                    </div>\n                    <div class=\"p-6 relative -mt-12\">\n                        <h3 class=\"text-2xl font-heading font-bold text-white mb-2 group-hover:text-orange-500 transition-colors\">Le Menu Bledar</h3>\n                        <p class=\"text-gray-400 text-sm mb-4 line-clamp-2\">Notre sandwich signature aux saveurs orientales, œuf, fromage et sauce maison.</p>\n                        <div class=\"flex items-center justify-between\">\n                            <span class=\"text-xl font-heading font-bold text-orange-500\">8.90 €</span>\n                            <button class=\"w-10 h-10 rounded bg-white/10 hover:bg-orange-500 flex items-center justify-center text-white transition-colors\">\n                                <span class=\"iconify\" data-icon=\"lucide:plus\"></span>\n                            </button>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Card 2 -->\n                <div class=\"group bg-[#151515] rounded-xl overflow-hidden border border-white/5 hover:border-orange-500/50 transition-all duration-300\">\n                    <div class=\"h-64 overflow-hidden relative\">\n                        <img src=\"https://images.unsplash.com/photo-1626082927389-e1606d5080e6?q=80&amp;w=800&amp;auto=format&amp;fit=crop\" alt=\"Bucket Tenders\" class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-110\">\n                        <div class=\"absolute inset-0 bg-gradient-to-t from-[#151515] to-transparent\"></div>\n                    </div>\n                    <div class=\"p-6 relative -mt-12\">\n                        <h3 class=\"text-2xl font-heading font-bold text-white mb-2 group-hover:text-orange-500 transition-colors\">Bucket Tenders</h3>\n                        <p class=\"text-gray-400 text-sm mb-4 line-clamp-2\">10 pièces de filets de poulet panés croustillants, parfait à partager.</p>\n                        <div class=\"flex items-center justify-between\">\n                            <span class=\"text-xl font-heading font-bold text-orange-500\">14.50 €</span>\n                            <button class=\"w-10 h-10 rounded bg-white/10 hover:bg-orange-500 flex items-center justify-center text-white transition-colors\">\n                                <span class=\"iconify\" data-icon=\"lucide:plus\"></span>\n                            </button>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Card 3 -->\n                <div class=\"group bg-[#151515] rounded-xl overflow-hidden border border-white/5 hover:border-orange-500/50 transition-all duration-300\">\n                    <div class=\"h-64 overflow-hidden relative\">\n                        <img src=\"https://images.unsplash.com/photo-1572490122747-3968b75cc699?q=80&amp;w=800&amp;auto=format&amp;fit=crop\" alt=\"Milkshake Kinder\" class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-110\">\n                        <div class=\"absolute inset-0 bg-gradient-to-t from-[#151515] to-transparent\"></div>\n                    </div>\n                    <div class=\"p-6 relative -mt-12\">\n                        <h3 class=\"text-2xl font-heading font-bold text-white mb-2 group-hover:text-orange-500 transition-colors\">Milkshake Kinder</h3>\n                        <p class=\"text-gray-400 text-sm mb-4 line-clamp-2\">Glace onctueuse mixée avec de véritables barres Kinder Bueno.</p>\n                        <div class=\"flex items-center justify-between\">\n                            <span class=\"text-xl font-heading font-bold text-orange-500\">4.50 €</span>\n                            <button class=\"w-10 h-10 rounded bg-white/10 hover:bg-orange-500 flex items-center justify-center text-white transition-colors\">\n                                <span class=\"iconify\" data-icon=\"lucide:plus\"></span>\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- NOTRE MENU -->\n    <section id=\"menu\" class=\"py-20 bg-[#050505] relative\">\n        <!-- Texture Background -->\n        <div class=\"absolute inset-0 opacity-5 pointer-events-none\" style=\"background-image: url('https://www.transparenttextures.com/patterns/cubes.png');\"></div>\n\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10\">\n            <div class=\"text-center mb-16\">\n                <span class=\"text-orange-500 font-heading font-bold tracking-widest text-sm uppercase\">Fait Maison &amp; Généreux</span>\n                <h2 class=\"text-5xl md:text-6xl font-heading font-bold text-white mt-2\">NOTRE CARTE</h2>\n            </div>\n\n            <!-- Categories Tabs -->\n            <div class=\"flex overflow-x-auto hide-scrollbar gap-4 pb-