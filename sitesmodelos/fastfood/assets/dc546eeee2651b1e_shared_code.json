Item -->\n                 <div class=\"flex gap-4 p-4 rounded-lg hover:bg-white/5 transition-colors border border-transparent hover:border-white/10 group\">\n                    <img src=\"https://images.unsplash.com/photo-1529042410759-befb1204b468?q=80&amp;w=200&amp;auto=format&amp;fit=crop\" class=\"w-24 h-24 rounded object-cover shrink-0\" alt=\"Le French\">\n                    <div class=\"flex flex-col flex-grow justify-between\">\n                        <div>\n                            <div class=\"flex justify-between items-start\">\n                                <h4 class=\"text-xl font-heading font-bold text-white group-hover:text-orange-500 transition-colors\">LE FRENCH</h4>\n                                <span class=\"text-orange-500 font-bold font-heading text-lg\">7.90 €</span>\n                            </div>\n                            <p class=\"text-sm text-gray-400 mt-1\">Steak, œuf à cheval, fromage emmental, salade, tomate.</p>\n                        </div>\n                        <div class=\"mt-2 flex gap-2\">\n                            <span class=\"text-[10px] uppercase border border-green-500/30 text-green-400 px-2 py-0.5 rounded\">Avec Œuf</span>\n                        </div>\n                    </div>\n                </div>\n\n                 <!-- Category: Buckets -->\n                 <div class=\"col-span-full mt-8 mb-4 flex items-center gap-4\">\n                    <span class=\"iconify text-orange-500\" data-icon=\"lucide:drumstick\" data-width=\"32\"></span>\n                    <h3 class=\"text-3xl font-heading font-bold text-white\">CHICKEN HOUSE</h3>\n                    <div class=\"h-px bg-white/10 flex-grow\"></div>\n                </div>\n\n                <div class=\"p-6 bg-[#121212] border border-white/5 rounded-xl hover:border-orange-500/30 transition-colors\">\n                    <h4 class=\"text-2xl font-heading font-bold text-white mb-2\">BUCKET SOLO</h4>\n                    <p class=\"text-gray-400 text-sm mb-4\">6 Tenders ou 8 Wings + 1 Frites + 1 Boisson 33cl</p>\n                    <span class=\"text-2xl font-heading font-bold text-orange-500\">10.90 €</span>\n                </div>\n\n                <div class=\"p-6 bg-[#121212] border border-white/5 rounded-xl hover:border-orange-500/30 transition-colors relative overflow-hidden\">\n                    <div class=\"absolute -right-4 -top-4 bg-orange-600 w-16 h-16 rotate-45\"></div>\n                    <h4 class=\"text-2xl font-heading font-bold text-white mb-2\">BUCKET FAMILIAL</h4>\n                    <p class=\"text-gray-400 text-sm mb-4\">20 Tenders ou 30 Wings + 4 Frites + 1 Bouteille 1.5L</p>\n                    <span class=\"text-2xl font-heading font-bold text-orange-500\">32.90 €</span>\n                </div>\n\n            </div>\n            \n            <div class=\"mt-16 text-center\">\n                <button class=\"border border-orange-500 text-orange-500 hover:bg-orange-500 hover:text-white px-8 py-3 rounded font-heading font-bold tracking-wider transition-all\">\n                    TÉLÉCHARGER LA CARTE PDF\n                </button>\n            </div>\n        </div>\n    </section>\n\n    <!-- ALLERGENES SECTION -->\n    <section id=\"allergens\" class=\"py-16 bg-[#0a0a0a] border-t border-white/5\">\n        <div class=\"max-w-4xl mx-auto px-4\">\n            <div class=\"text-center mb-10\">\n                <span class=\"iconify text-orange-500 mx-auto mb-4\" data-icon=\"lucide:shield-check\" data-width=\"40\"></span>\n                <h2 class=\"text-3xl font-heading font-bold text-white\">INFORMATIONS ALLERGÈNES</h2>\n                <p class=\"text-gray-400 mt-2 text-sm\">Votre sécurité est notre priorité. Voici le tableau des 14 allergènes majeurs.</p>\n            </div>\n\n            <div class=\"bg-[#151515] rounded-lg border border-white/10 overflow-hidden shadow-2xl\">\n                <div class=\"overflow-x-auto\">\n                    <table class=\"w-full