-bottom-8 -right-8 w-32 h-32 border border-[#a38a5e]/20 hidden md:block\"></div>\n                </div>\n                \n                <div class=\"order-1 lg:order-2 lg:pl-12\">\n                    <span class=\"text-xs uppercase tracking-[0.2em] text-[#a38a5e] mb-4 block\">The Art of Extraction</span>\n                    <h2 class=\"font-['Cormorant_Garamond',_serif] text-3xl md:text-5xl font-medium tracking-tight text-white mb-8 leading-tight\">\n                        A symphony of <br/> rare botanicals\n                    </h2>\n                    <p class=\"text-sm text-[#9a9488] mb-6 font-light leading-relaxed\">\n                        Every bottle holds a narrative. We source the world's most elusive ingredients, from the damp, shaded floors of Indonesian forests to the sun-drenched valleys of Grasse.\n                    </p>\n                    <p class=\"text-sm text-[#9a9488] mb-10 font-light leading-relaxed\">\n                        Our master perfumers blend traditional maceration techniques with modern precision, resulting in scents that evolve beautifully on the skin—revealing new depths hour by hour.\n                    </p>\n                    \n                    <a href=\"#\" class=\"group inline-flex items-center text-xs uppercase tracking-[0.15em] text-[#e3ded5] hover:text-[#a38a5e] transition-colors duration-300\">\n                        Discover Our Process\n                        <iconify-icon icon=\"solar:arrow-right-linear\" class=\"ml-2 text-lg transform group-hover:translate-x-1 transition-transform\"></iconify-icon>\n                    </a>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Footer -->\n    <footer class=\"bg-[#0a0a09] pt-24 pb-12 border-t border-white/5 mt-auto\">\n        <div class=\"max-w-7xl mx-auto px-6 md:px-12\">\n            <div class=\"grid grid-cols-1 md:grid-cols-4 gap-12 mb-20\">\n                \n                <!-- Brand Column -->\n            