'fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n}\n</style></head>\n<body class=\"bg-[#050505] text-[#e5e5e5] font-sans antialiased selection:bg-[#78350f] selection:text-white overflow-x-hidden\">\n\n    <!-- Noise Overlay -->\n    <div class=\"bg-grain\"></div>\n\n    <!-- Announcement Bar -->\n    <div class=\"bg-[#1c1917] text-[#a8a29e] py-2 text-[10px] uppercase text-center tracking-[0.2em] font-medium border-b border-white/5\">\n        Complimentary Global Shipping • Obsidian Series\n    </div>\n\n    <!-- Navigation -->\n    <nav class=\"sticky top-0 z-40 w-full backdrop-blur-xl bg-[#050505]/70 border-b border-white/5 supports-[backdrop-filter]:bg-[#050505]/50\">\n        <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\">\n            <!-- Mobile Menu -->\n            <button class=\"md:hidden p-2 -ml-2 text-[#a8a29e] hover:text-white transition-colors\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" class=\"iconify iconify--lucide\"><path fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M4 5h16M4 12h16M4 19h16\"></path></svg>\n            </button>\n\n            <!-- Logo -->\n            <a href=\"#\" class=\"font-['Space_Grotesk'] font-bold text-2xl tracking-tighter uppercase z-10 text-white\">\n                Lovfoot<span class=\"text-[#78350f]\">.</span>\n            </a>\n\n            <!-- Desktop Links -->\n            <div class=\"hidden md:flex items-center space-x-10 absolute left-1/2 transform -translate-x-1/2\">\n                <a href=\"#\" class=\"text-xs font-medium uppercase tracking-widest text-[#a8a29e] hover:text-white transition-colors\">Collection</a>\n                <a href=\"#\" class=\"text-xs font-medium uppercase tracking-widest text-[#a8a29e] hover:text-white transition-colors\">Atelier</a>\n                <a href=\"#\" class=\"text-xs font-medium uppercase tracking-widest text-[#a8a29e] hover:text-white transition-colors\">Performance</a>\n            </div>\n\n            <!-- Icons -->\n            <div class=\"flex items-center space-x-6\">\n                <button class=\"text-[#a8a29e] hover:text-white transition-transform hover:scale-105\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" class=\"iconify iconify--lucide\"><g fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\"><path d=\"m21 21l-4.34-4.34\"></path><circle cx=\"11\" cy=\"11\" r=\"8\"></circle></g></svg>\n                </button>\n                <button class=\"text-[#a8a29e] hover:text-white transition-transform hover:scale-105 relative\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" class=\"iconify iconify--lucide\"><g fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\"><path d=\"M16 10a4 4 0 0 1-8 0M3.103 6.034h17.794\"></path><path d=\"M3.4 5.467a2 2 0 0 0-.4 1.2V20a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6.667a2 2 0 0 0-.4-1.2l-2-2.667A2 2 0 0 0 17 2H7a2 2 0 0 0-1.6.8z\"></path></g></svg>\n                    <span class=\"absolute -top-1 -right-1 w-1.5 h-1.5 bg-[#d97706] rounded-full\"></span>\n                </button>\n            </div>\n        </div>\n    </nav>\n\n    <!-- Hero Section -->\n    <header class=\"relative w-full h-[90vh] overflow-hidden flex flex-col justify-center items-center bg-[#050505]\">\n        <!-- Background with Advanced Gradient Filters -->\n        <div class=\"absolute inset-0 z-0\">\n            <!-- Used Sepia and Contrast to force the image into the Brown/Black theme -->\n            <img src=\"https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=2070&auto=format&fit=crop\" \n                 alt=\"Signature Shoe\" \n                 class=\"w-full h-full object-cover object-center grayscale-[50%] sepia-[40%] brightness-[0.7] contrast-[1.2]\">\n            \n            <!-- Vignette & Gradient Overlays -->\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[#050505] via-[#050505]/40 to-transparent\"></div>\n            <div class=\"absolute inset-0 bg-gradient-to-r from-[#050505]/80 via-transparent to-[#050505]/80\"></div>\n            <div class=\"absolute inset-0 bg-[#291e15] mix-blend-overlay opacity-40\"></div>\n        </div>\n\n        <div class=\"relative z-10 text-center px-6 max-w-5xl mx-auto animate-fade-in\">\n            <span class=\"inline-block py-1.5 px-4 border border-[#d97706]/30 text-[#d97706] rounded-full text-[10px] font-bold tracking-[0.2em] uppercase backdrop-blur-md mb-8 bg-black/20\">\n                Series 04 — Carbon\n            </span>\n            <h1 class=\"font-['Space_Grotesk'] text-5xl md:text-7xl lg:text-9xl tracking-tighter leading-[0.9] mb-8 text-transparent bg-clip-text bg-gradient-to-b from-white to-[#78716c]\">\n                Primal <br> Elegance.\n            </h1>\n            <p class=\"text-[#a8a29e] text-sm md:text-lg max-w-lg mx-auto mb-12 leading-relaxed font-light tracking-wide\">\n                Engineered from the ground up. A fusion of raw earth tones and aerospace-grade composites.\n            </p>\n            <div class=\"flex flex-col sm:flex-row items-center justify-center gap-6\">\n                <a href=\"#\" class=\"group relative px-8 py-4 bg-[#e5e5e5] text-black text-xs font-bold uppercase tracking-widest overflow-hidden\">\n                    <span class=\"relative z-10 group-hover:text-white transition-colors duration-300\">Explore Men</span>\n                    <div class=\"absolute inset-0 bg-[#451a03] transform scale-x-0 origin-left group-hover:scale-x-100 transition-transform duration-300 ease-out\"></div>\n                </a>\n                <a href=\"#\" class=\"group px-8 py-4 text-xs font-bold uppercase tracking-widest text-white border border-white/20 hover:bg-white/5 transition-all\">\n                    Explore Women\n                </a>\n            </div>\n        </div>\n        \n        <!-- Scrolling Ticker -->\n        <div class=\"absolute bottom-0 w-full border-t border-white/5 bg-black/40 backdrop-blur-md py-5 overflow-hidden flex whitespace-nowrap z-20\">\n            <div class=\"animate-marquee inline-block px-4 text-[10px] font-bold text-[#78716c] tracking-[0.3em] uppercase\">\n                • Carbon Plate Architecture • Hand-finished Leather Details • Adaptive Foam • Reactive Sole • \n                Carbon Plate Architecture • Hand-finished Leather Details • Adaptive Foam • Reactive Sole\n            </div>\n        </div>\n    </header>\n\n    <!-- Curated Collection -->\n    <section class=\"py-32 px-6 max-w-7xl mx-auto relative\">\n        <!-- Decoration -->\n        <div class=\"absolute top-1/4 left-0 w-[500px] h-[500px] bg-[#451a03] rounded-full blur-[120px] opacity-20 pointer-events-none\"></div>\n\n        <div class=\"flex flex-col md:flex-row justify-between items-end mb-16 relative z-10\">\n            <div>\n                <h2 class=\"font-['Space_Grotesk'] text-3xl md:text-5xl tracking-tighter text-white mb-3\">The Earth Palette</h2>\n                <p class=\"text-[#78716c] text-sm tracking-wide\">Inspired by terrain. Built for velocity.</p>\n            </div>\n            <a href=\"#\" class=\"hidden md:flex items-center text-xs font-bold uppercase tracking-widest text-[#d97706] hover:text-white transition-colors mt-4 md:mt-0\">\n                View All Models <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" class=\"iconify ml-2 iconify--lucide\"><path fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M7 7h10v10M7 17L17 7\"></path></svg>\n            </a>\n        </div>\n\n        <!-- Bento Grid -->\n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 relative z-10\">\n            \n            <!-- Hero Card -->\n            <div class=\"md:col-span-2 group relative bg-[#0c0a09] border border-white/5 overflow-hidden aspect-[16/9] md:aspect-auto\">\n                <img src=\"https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?q=80&w=1664&auto=format&fit=crop\" alt=\"Sneaker\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 opacity-60 grayscale-[80%] sepia-[20%] group-hover:grayscale-[40%]\">\n                <div class=\"absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent\"></div>\n                \n                <div class=\"absolute bottom-0 left-0 p-8 md:p-12 w-full\">\n                    <span class=\"text-[#d97706] text-[10px] tracking-[0.2em] uppercase font-bold mb-2 block\">Limited Edition</span>\n                    <h3 class=\"font-['Space_Grotesk'] text-3xl text-white mb-2\">Apex Terra</h3>\n                    <p class=\"text-sm text-[#a8a29e] mb-6 max-w-sm opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 delay-100\">\n                        Rugged durability meets metropolitan style in a silhouette defined by contrast.\n                    </p>\n                    <button class=\"text-white text-xs font-bold uppercase tracking-widest border-b border-white pb-1 hover:text-[#d97706] hover:border-[#d97706] transition-colors\">\n                        Shop Now\n                    </button>\n                </div>\n            </div>\n\n            <!-- Product Card 1 -->\n            <div class=\"group relative bg-[#0c0a09] border border-white/5 p-8 flex flex-col justify-between hover:border-[#451a03] transition-colors duration-500\">\n                <div class=\"absolute top-0 right-0 p-6 opacity-0 group-hover:opacity-100 transition-opacity\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" class=\"iconify text-white iconify--lucide\"><path fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M12 5v14m-7-7h14\"></path></svg>\n                </div>\n                \n                <div class=\"relative w-full aspect-square mb-8 flex items-center justify-center\">\n                    <div class=\"absolute w-32 h-32 bg-[#451a03] rounded-full blur-[60px] opacity-20 group-hover:opacity-40 transition-opacity duration-500\"></div>\n                    <img src=\"https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?q=80&w=987&auto=format&fit=crop\" class=\"w-full h-full object-contain grayscale-[100%] brightness-[1.2] sepia-[0.3] group-hover:-translate-y-4 transition-transform duration-700 ease-out\" alt=\"Shoe\">\n                </div>\n                \n                <div>\n                    <div class=\"flex justify-between items-end border-t border-white/10 pt-4\">\n                        <div>\n                            <p class=\"text-[10px] text-[#78716c] uppercase tracking-widest mb-1\">Trail</p>\n                            <h3 class=\"font-['Space_Grotesk'] text-lg text-white\">Dune Hiker</h3>\n                        </div>\n                        <span class=\"text-sm font-medium text-[#d97706]\">$225</span>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Product Card 2 -->\n            <div class=\"group relative bg-[#0c0a09] border border-white/5 p-8 flex flex-col justify-between hover:border-[#451a03] transition-colors duration-500\">\n                <div class=\"relative w-full aspect-square mb-8 flex items-center justify-center\">\n                    <div class=\"absolute w-32 h-32 bg-[#78350f] rounded-full blur-[60px] opacity-20 group-hover:opacity-40 transition-opacity duration-500\"></div>\n                    <img src=\"https://images.unsplash.com/photo-1560769629-975ec94e6a86?q=80&w=1064&auto=format&fit=crop\" class=\"w-full h-full object-contain grayscale-[80%] brightness-[1.1] sepia-[0.2] group-hover:-translate-y-4 transition-transform duration-700 ease-out\" alt=\"Shoe\">\n                </div>\n                \n                <div>\n                    <div class=\"flex justify-between items-end border-t border-white/10 pt-4\">\n                        <div>\n                            <p class=\"text-[10px] text-[#78716c] uppercase tracking-widest mb-1\">Urban</p>\n                            <h3 class=\"font-['Space_Grotesk'] text-lg text-white\">Obsidian Walker</h3>\n                        </div>\n                        <span class=\"text-sm font-medium text-[#d97706]\">$195</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Technical Specs -->\n    <section class=\"bg-[#050505] py-32 overflow-hidden relative border-y border-white/5\">\n        <!-- Abstract Tech Background -->\n        <div class=\"absolute inset-0 opacity-10\" style=\"background-image: radial-gradient(#451a03 1px, transparent 1px); background-size: 32px 32px;\"></div>\n        \n        <div class=\"max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-20 items-center relative z-10\">\n            <div class=\"order-2 md:order-1\">\n                <span class=\"text-[#d97706] font-mono text-[10px] tracking-[0.3em] uppercase mb-6 block\">Specifications</span>\n                <h2 class=\"font-['Space_Grotesk'] text-4xl md:text-6xl text-white tracking-tighter mb-8 leading-[1]\">\n                    Defying <br> <span class=\"text-[#44403c]\">Gravity.</span>\n                </h2>\n                <p class=\"text-[#a8a29e] text-sm leading-relaxed mb-10 max-w-md\">\n                    Our proprietary compound creates a responsive energy return system that feels organic yet powerful. Wrapped in ethically sourced materials dyed with natural earth pigments.\n                </p>\n\n                <div class=\"space-y-px bg-white/10\">\n                    <div class=\"group bg-[#050505] p-6 hover:bg-[#1c1917] transition-colors cursor-pointer border-l-2 border-transparent hover:border-[#d97706]\">\n                        <h4 class=\"text-white text-sm font-bold uppercase tracking-wider mb-2 flex justify-between items-center\">\n                            Composite Shank \n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" class=\"iconify text-[#44403c] group-hover:text-white transition-colors iconify--lucide\"><path fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M12 5v14m-7-7h14\"></path></svg>\n                        </h4>\n                        <p class=\"text-xs text-[#78716c]\">Rigid stability for uneven terrain.</p>\n                    </div>\n                    <div class=\"group bg-[#050505] p-6 hover:bg-[#1c1917] transition-colors cursor-pointer border-l-2 border-transparent hover:border-[#d97706]\">\n                        <h4 class=\"text-white text-sm font-bold uppercase tracking-wider mb-2 flex justify-between items-center\">\n                            Espresso Knit\n                             <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" class=\"iconify text-[#44403c] group-hover:text-white transition-colors iconify--lucide\"><path fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M12 5v14m-7-7h14\"></path></svg>\n                        </h4>\n                        <p class=\"text-xs text-[#78716c]\">Breathable, high-tensile fiber weave.</p>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"relative order-1 md:order-2 flex justify-center\">\n                <!-- Glowing Circle -->\n                <div class=\"absolute inset-0 bg-gradient-to-tr from-[#451a03] to-transparent opacity-30 blur-3xl rounded-full\"></div>\n                \n                <div class=\"relative w-full aspect-square max-w-md bg-[#0c0a09] rounded-full border border-white/5 flex items-center justify-center shadow-2xl shadow-black\">\n                    <img src=\"https://images.unsplash.com/photo-1515955656352-a1fa3ffcd111?q=80&w=2070&auto=format&fit=crop\" alt=\"Sole\" class=\"absolute w-[115%] max-w-none grayscale-[100%] sepia-[50%] brightness-[0.8] mix-blend-screen rotate-12 hover:rotate-0 transition-transform duration-[1.5s] ease-in-out\">\n                </div>\n                \n                <!-- Floating Data Points -->\n                <div class=\"absolute top-0 right-10 bg-[#1c1917]/80 backdrop-blur-md p-4 border border-white/10\">\n                    <p class=\"text-[10px] text-[#78716c] uppercase tracking-widest mb-1\">Weight</p>\n                    <p class=\"text-xl text-white font-mono\">198<span class=\"text-xs text-[#57534e]\">g</span></p>\n                </div>\n                <div class=\"absolute bottom-10 left-0 bg-[#1c1917]/80 backdrop-blur-md p-4 border border-white/10\">\n                    <p class=\"text-[10px] text-[#78716c] uppercase tracking-widest mb-1\">Drop</p>\n                    <p class=\"text-xl text-white font-mono\">8<span class=\"text-xs text-[#57534e]\">mm</span></p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Lifestyle Visual -->\n    <section class=\"py-24 px-6 max-w-7xl mx-auto\">\n        <div class=\"relative h-[700px] w-full group overflow-hidden\">\n            <img src=\"https://images.unsplash.com/photo-1516762689617-e1cffcef479d?q=80&w=2011&auto=format&fit=crop\" alt=\"Lifestyle\" class=\"absolute inset-0 w-full h-full object-cover grayscale-[100%] sepia-[20%] brightness-[0.6] transition-transform duration-[2s] group-hover:scale-105\"