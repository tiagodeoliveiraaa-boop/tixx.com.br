[{"id":26674,"slug":"elite-fitness-76","title":"Elite Fitness Coaching Landing Page Template","code":"<!DOCTYPE html>\n<html lang=\"en\" class=\"scroll-smooth\"><head><meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Coaching by Andy | Elite Physique Transformation</title>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<script src=\"https://unpkg.com/lucide@latest\"></script>\n<style>\n/* Base typography adjustments per instructions */\nbody {\nbackground-color: #0a0a0a;\ncolor: #ffffff;\n}\n::selection {\nbackground-color: #e7ff72;\ncolor: #000000;\n}\n/* Hide scrollbar for the credentials marquee effect if it overflows */\n.no-scrollbar::-webkit-scrollbar {\ndisplay: none;\n}\n.no-scrollbar {\n-ms-overflow-style: none;\nscrollbar-width: none;\n}\n</style><!-- aura-ga4-start -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-2M6V79H761\"></script>\n<script>\nwindow.dataLayer = window.dataLayer || [];\nfunction gtag(){dataLayer.push(arguments);}\ngtag('js', new Date());\ngtag('config', 'G-2M6V79H761');\n</script>\n<!-- aura-ga4-end -->\n</head>\n<body class=\"font-sans antialiased selection:bg-[#e7ff72] selection:text-black min-h-screen flex flex-col\">\n\n    <!-- Navigation -->\n    <nav class=\"fixed top-0 w-full z-50 bg-[#0a0a0a]/80 backdrop-blur-md border-b border-white/5\">\n        <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\">\n            <!-- Typographic Logo Fallback representing Image 2 -->\n            <a href=\"#\" class=\"flex items-center select-none\">\n                <div class=\"relative inline-block text-4xl tracking-tighter uppercase\" style=\"font-family: Impact, sans-serif; color: #e7ff72;\">\n                    AN<span class=\"relative inline-block\">D<span class=\"absolute top-1/2 left-[45%] -translate-x-1/2 -translate-y-[45%] text-[0.18em] text-white tracking-normal whitespace-nowrap\" style=\"font-family: sans-serif;\">COACHING BY</span></span>Y\n                </div>\n            </a>\n\n            <!-- Desktop Menu -->\n            <div class=\"hidden md:flex items-center gap-8\">\n                <a href=\"#services\" class=\"text-lg text-gray-400 hover:text-white transition-colors font-medium\">Services</a>\n                <a href=\"#results\" class=\"text-lg text-gray-400 hover:text-white transition-colors font-medium\">Results</a>\n                <a href=\"#credentials\" class=\"text-lg text-gray-400 hover:text-white transition-colors font-medium\">About</a>\n                <a href=\"#apply\" class=\"bg-[#e7ff72] text-black px-5 py-2.5 rounded-full font-semibold text-lg hover:bg-white transition-colors\">\n                    Apply Now\n                </a>\n            </div>\n\n            <!-- Mobile Menu Toggle (Visual only for layout) -->\n            <button class=\"md:hidden text-white p-2\">\n                <i data-lucide=\"menu\" stroke-width=\"1.5\" class=\"w-6 h-6\"></i>\n            </button>\n        </div>\n    </nav>\n\n    <!-- Hero Section -->\n    <main class=\"flex-grow lg:pt-40 lg:pb-32 overflow-hidden pt-32 pr-6 pb-20 pl-6\">\n        <div class=\"max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16 lg:gap-8\">\n            \n            <!-- Left: Copy -->\n            <div class=\"flex-1 space-y-8 z-10 w-full\">\n                <div class=\"inline-flex gap-2 text-sm font-medium text-[#e7ff72] bg-[#e7ff72]/5 border-[#e7ff72]/30 border rounded-full mb-4 pt-1 pr-3 pb-1 pl-3 gap-x-2 gap-y-2 items-center\">Accepting New Clients <span class=\"relative flex h-2 w-2\">\n                      <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-[#e7ff72] opacity-75\"></span>\n                      <span class=\"relative inline-flex rounded-full h-2 w-2 bg-[#e7ff72]\"></span>\n                    </span></div>\n                \n                <h1 class=\"md:text-7xl lg:text-8xl uppercase leading-[0.9] text-6xl tracking-tighter\" style=\"font-family: Impact, sans-serif\">\n    Transform <br>\n    <span class=\"text-[#e7ff72]\">Your Physique.</span> <br>\n    No BS.\n</h1>\n                \n                <p class=\"md:text-xl leading-relaxed text-lg font-medium text-gray-400 max-w-xl\">Efficiency, accountability, and aesthetic results for busy professionals in Hong Kong and worldwide. A proven system that respects your time.</p>\n                \n                <div class=\"flex flex-col sm:flex-row gap-4 pt-4\">\n                    <a href=\"#apply\" class=\"hover:bg-white transition-all flex items-center justify-center gap-2 group text-lg font-semibold text-black text-center bg-[#e7ff72] rounded-full pt-4 pr-8 pb-4 pl-8\">\n                        Start Your Transformation\n                        <i data-lucide=\"arrow-right\" stroke-width=\"1.5\" class=\"w-5 h-5 group-hover:translate-x-1 transition-transform\"></i>\n                    </a>\n                    <a href=\"#services\" class=\"px-8 py-4 rounded-full font-medium text-lg border border-white/10 hover:border-white/30 transition-colors text-center bg-[#151515]/50 backdrop-blur-sm\">\n                        View Coaching Options\n                    </a>\n                </div>\n            </div>\n\n            <!-- Right: Image & Stats (Representing Image 1) -->\n            <div class=\"flex-1 relative w-full max-w-md lg:max-w-none mx-auto\">\n                <div class=\"relative aspect-[3/4] lg:aspect-[4/5] bg-[#151515] rounded-3xl overflow-hidden border border-white/10 shadow-2xl\">\n                    <!-- Placeholder using a gritty aesthetic fitness image -->\n                    <img src=\"https://images.unsplash.com/photo-1581009146145-b5ef050c2e1e?q=80&w=2070&auto=format&fit=crop\" alt=\"Coach Andy Professional Bodybuilder\" class=\"w-full h-full object-cover opacity-70 mix-blend-luminosity hover:mix-blend-normal transition-all duration-700 object-top\">\n                    <div class=\"absolute top-0 right-0 bottom-0 left-0 bg-gradient-to-br from-[#e7ff72]/95 to-white/0 lg:bg-clip-text lg:text-transparent\"></div>\n                </div>\n\n                <!-- Floating Stat 1 -->\n                <div class=\"absolute -left-4 lg:-left-12 top-12 lg:top-24 bg-[#151515]/90 backdrop-blur-xl border border-white/10 p-5 rounded-2xl shadow-xl transform hover:scale-105 transition-transform\">\n                    <div class=\"text-4xl lg:text-5xl text-[#e7ff72] tracking-tighter\" style=\"font-family: Impact, sans-serif;\">100+</div>\n                    <div class=\"text-lg text-white font-medium mt-1\">Transformations</div>\n                    <div class=\"text-sm text-gray-500 font-medium\">Proven global success</div>\n                </div>\n\n                <!-- Floating Stat 2 -->\n                <div class=\"absolute -right-4 lg:-right-8 bottom-12 lg:bottom-24 bg-[#151515]/90 backdrop-blur-xl border border-white/10 p-5 rounded-2xl shadow-xl transform hover:scale-105 transition-transform\">\n                    <div class=\"text-4xl lg:text-5xl text-white tracking-tighter\" style=\"font-family: Impact, sans-serif;\">4+</div>\n                    <div class=\"text-lg text-[#e7ff72] font-medium mt-1\">Years Experience</div>\n                    <div class=\"text-sm text-gray-500 font-medium\">Professional coaching</div>\n                </div>\n            </div>\n        </div>\n    </main>\n\n    <!-- Credibility Bar -->\n    <section id=\"credentials\" class=\"border-y border-white/5 bg-[#151515]/30 py-8 overflow-hidden relative\">\n        <div class=\"z-10 bg-gradient-to-r from-[#0a0a0a] to-transparent w-24 absolute top-0 bottom-0 left-0\"></div>\n        <div class=\"absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-[#0a0a0a] to-transparent z-10\"></div>\n        \n        <div class=\"max-w-7xl mx-auto px-6 flex overflow-x-auto no-scrollbar items-center gap-12 lg:gap-20 text-gray-400 text-lg font-medium whitespace-nowrap\">\n            <div class=\"flex gap-3 gap-x-3 gap-y-3 items-center\">Bodybuilding<i data-lucide=\"medal\" stroke-width=\"1.5\" class=\"w-6 h-6 text-[#e7ff72]\"></i><span class=\"tracking-tight text-white\">9x Gold Medalist</span></div>\n            <div class=\"flex items-center gap-3\">\n                <i data-lucide=\"dumbbell\" stroke-width=\"1.5\" class=\"w-6 h-6 text-[#e7ff72]\"></i>\n                <span class=\"tracking-tight text-white\">Pro Prep Coach</span> \n            </div>\n            <div class=\"flex items-center gap-3\">\n                <i data-lucide=\"award\" stroke-width=\"1.5\" class=\"w-6 h-6 text-[#e7ff72]\"></i>\n                <span class=\"tracking-tight text-white\">NASM Certified</span> Personal Trainer\n            </div>\n            <div class=\"flex items-center gap-3\">\n                <i data-lucide=\"apple\" stroke-width=\"1.5\" class=\"w-6 h-6 text-[#e7ff72]\"></i>\n                <span class=\"tracking-tight text-white\">Certified</span> Nutrition Specialist\n            </div>\n            <div class=\"flex items-center gap-3\">\n                <i data-lucide=\"activity\" stroke-width=\"1.5\" class=\"w-6 h-6 text-[#e7ff72]\"></i>\n                <span class=\"tracking-tight text-white\">Hyrox Coach</span> Performance\n            </div>\n        </div>\n    </section>\n\n    <!-- Services Section -->\n    <section class=\"lg:py-32 pt-24 pr-6 pb-24 pl-6\" id=\"services\">\n        <div class=\"max-w-7xl mr-auto ml-auto\">\n            <div class=\"text-center mb-20\">\n                <h2 class=\"md:text-6xl uppercase text-5xl tracking-tighter mb-6\" style=\"font-family: Impact, sans-serif;\">elite services</h2>\n                <p class=\"md:text-xl text-lg font-medium text-gray-400 max-w-2xl mr-auto ml-auto\">Tailored solutions for your specific goals, lifestyle, and location.</p>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8\">\n                \n                <!-- Service 1: In-Person -->\n                <div class=\"bg-[#151515] p-8 lg:p-10 rounded-3xl border border-white/5 hover:border-[#e7ff72]/50 transition-all duration-300 group relative overflow-hidden flex flex-col\">\n                    <div class=\"absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity transform group-hover:scale-110 duration-500\">\n                        <i data-lucide=\"map-pin\" stroke-width=\"1.5\" class=\"w-32 h-32 text-[#e7ff72]\"></i>\n                    </div>\n                    <div class=\"w-14 h-14 bg-[#0a0a0a] border border-white/10 rounded-2xl flex items-center justify-center mb-8 text-[#e7ff72] group-hover:bg-[#e7ff72] group-hover:text-black transition-colors\">\n                        <i data-lucide=\"map-pin\" stroke-width=\"1.5\" class=\"w-6 h-6\"></i>\n                    </div>\n                    <h3 class=\"text-3xl font-semibold text-white tracking-tight mb-4\">In-Person HK</h3>\n                    <p class=\"flex-grow text-lg font-medium text-gray-400 mb-8\">The ultimate local experience. Hands-on, intensive sessions in Hong Kong. Focus on flawless execution, immediate feedback, and maximizing your time efficiency.</p>\n                    <ul class=\"space-y-3 mb-8 text-lg font-medium text-gray-300\">\n                        <li class=\"flex items-center gap-3\"><i data-lucide=\"check\" stroke-width=\"1.5\" class=\"w-5 h-5 text-[#e7ff72]\"></i> 1-on-1 Private Sessions</li>\n                        <li class=\"flex items-center gap-3\"><i data-lucide=\"check\" stroke-width=\"1.5\" class=\"w-5 h-5 text-[#e7ff72]\"></i> Form Correction &amp; Optimization</li>\n                        <li class=\"flex items-center gap-3\"><i data-lucide=\"check\" stroke-width=\"1.5\" class=\"w-5 h-5 text-[#e7ff72]\"></i> Full Nutrition Protocol</li>\n                    </ul>\n                    <a href=\"#apply\" class=\"inline-flex items-center justify-between w-full bg-white/5 hover:bg-white/10 text-white px-6 py-4 rounded-xl font-semibold text-lg transition-colors border border-white/5\">\n                        Apply for HK Coaching <i data-lucide=\"arrow-right\" stroke-width=\"1.5\" class=\"w-5 h-5\"></i>\n                    </a>\n                </div>\n\n                <!-- Service 2: Online Global -->\n                <div class=\"bg-[#151515] p-8 lg:p-10 rounded-3xl border border-[#e7ff72]/20 hover:border-[#e7ff72]/50 transition-all duration-300 group relative overflow-hidden flex flex-col\">\n                    <div class=\"absolute top-0 right-0 bg-[#e7ff72] text-black text-sm font-semibold px-4 py-1 rounded-bl-xl z-10\">\n                        Most Popular\n                    </div>\n                    <div class=\"absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity transform group-hover:scale-110 duration-500\">\n                        <i data-lucide=\"globe\" stroke-width=\"1.5\" class=\"w-32 h-32 text-[#e7ff72]\"></i>\n                    </div>\n                    <div class=\"w-14 h-14 bg-[#0a0a0a] border border-white/10 rounded-2xl flex items-center justify-center mb-8 text-[#e7ff72] group-hover:bg-[#e7ff72] group-hover:text-black transition-colors\">\n                        <i data-lucide=\"globe\" stroke-width=\"1.5\" class=\"w-6 h-6\"></i>\n                    </div>\n                    <h3 class=\"text-3xl tracking-tight font-semibold mb-4 text-white\">Online Global</h3>\n                    <p class=\"text-lg text-gray-400 font-medium mb-8 flex-grow\">\n                        Andy's proven system delivered anywhere in the world. Comprehensive weekly check-ins, custom programming, and 24/7 access to ensure constant progression.\n                    </p>\n                    <ul class=\"space-y-3 mb-8 text-lg font-medium text-gray-300\">\n                        <li class=\"flex items-center gap-3\"><i data-lucide=\"check\" stroke-width=\"1.5\" class=\"w-5 h-5 text-[#e7ff72]\"></i> Custom Training App Access</li>\n                        <li class=\"flex items-center gap-3\"><i data-lucide=\"check\" stroke-width=\"1.5\" class=\"w-5 h-5 text-[#e7ff72]\"></i> Weekly Video Check-ins</li>\n                        <li class=\"flex items-center gap-3\"><i data-lucide=\"check\" stroke-width=\"1.5\" class=\"w-5 h-5 text-[#e7ff72]\"></i> Form Review via Video</li>\n                    </ul>\n                    <a href=\"#apply\" class=\"inline-flex items-center justify-between w-full bg-[#e7ff72] hover:bg-white text-black px-6 py-4 rounded-xl font-semibold text-lg transition-colors\">\n                        Apply for Global Coaching <i data-lucide=\"arrow-right\" stroke-width=\"1.5\" class=\"w-5 h-5\"></i>\n                    </a>\n                </div>\n\n                <!-- Service 3: Nutrition Only -->\n                <div class=\"lg:p-10 hover:border-[#e7ff72]/50 transition-all duration-300 group overflow-hidden flex flex-col bg-[#151515] border-white/5 border rounded-3xl pt-8 pr-8 pb-8 pl-8 relative\">\n                    <div class=\"w-14 h-14 bg-[#0a0a0a] border border-white/10 rounded-2xl flex items-center justify-center mb-8 text-[#e7ff72] group-hover:bg-[#e7ff72] group-hover:text-black transition-colors\">\n                        <i data-lucide=\"apple\" stroke-width=\"1.5\" class=\"w-6 h-6\"></i>\n                    </div>\n                    <h3 class=\"text-3xl tracking-tight font-semibold mb-4 text-white\">Nutrition Protocol</h3>\n                    <p class=\"text-lg text-gray-400 font-medium mb-8 flex-grow\">\n                        For those who have their training locked in but need expert guidance on macronutrients, meal timing, and supplementation to reveal their hard work.\n                    </p>\n                    <a href=\"#apply\" class=\"inline-flex items-center text-[#e7ff72] font-semibold text-lg hover:text-white transition-colors gap-2 group-hover:gap-3\">\n                        View Details <i data-lucide=\"arrow-right\" stroke-width=\"1.5\" class=\"w-5 h-5\"></i>\n                    </a>\n                </div>\n\n                <!-- Service 4: Premade Programs -->\n                <div class=\"bg-[#151515] p-8 lg:p-10 rounded-3xl border border-white/5 hover:border-[#e7ff72]/50 transition-all duration-300 group relative overflow-hidden flex flex-col\">\n                    <div class=\"w-14 h-14 bg-[#0a0a0a] border border-white/10 rounded-2xl flex items-center justify-center mb-8 text-[#e7ff72] group-hover:bg-[#e7ff72] group-hover:text-black transition-colors\">\n                        <i data-lucide=\"file-text\" stroke-width=\"1.5\" class=\"w-6 h-6\"></i>\n                    </div>\n                    <h3 class=\"text-3xl tracking-tight font-semibold mb-4 text-white\">Premade Programs</h3>\n                    <p class=\"text-lg text-gray-400 font-medium mb-8 flex-grow\">\n                        Scalable options based on Andy's core philosophies. 8-to-12 week structured routines focusing on hypertrophy, strength, or Hyrox prep. Independent execution.\n                    </p>\n                    <a href=\"#apply\" class=\"inline-flex items-center text-[#e7ff72] font-semibold text-lg hover:text-white transition-colors gap-2 group-hover:gap-3\">\n                        Browse Programs <i data-lucide=\"arrow-right\" stroke-width=\"1.5\" class=\"w-5 h-5\"></i>\n                    </a>\n                </div>\n\n            </div>\n        </div>\n    </section>\n\n    <!-- CTA Section -->\n    <section id=\"apply\" class=\"py-24 px-6 border-t border-white/5 bg-gradient-to-b from-[#0a0a0a] to-[#151515]\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"md:text-7xl uppercase text-6xl tracking-tighter mb-6\" style=\"font-family: Impact, sans-serif\">\n                Ready to <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-[#e7ff72] to-white\">Commit?</span>\n            </h2>\n            <p class=\"text-xl font-medium text-gray-400 max-w-2xl mr-auto mb-12 ml-auto\">\n                Join the 100+ individuals who have transformed their bodies and habits. Applications are reviewed within 24 hours.\n            </p>\n            <form class=\"max-w-md mx-auto space-y-4 text-left\">\n                <div class=\"\">\n                    <input type=\"text\" placeholder=\"Full Name\" class=\"placeholder:text-gray-600 focus:outline-none focus:border-[#e7ff72] transition-colors text-lg text-white bg-[#0a0a0a] w-full border-white/10 border rounded-xl pt-4 pr-5 pb-4 pl-5\">\n                </div>\n                <div class=\"\">\n                    <input type=\"email\" placeholder=\"Email Address\" class=\"w-full bg-[#0a0a0a] border border-white/10 rounded-xl px-5 py-4 text-lg text-white placeholder:text-gray-600 focus:outline-none focus:border-[#e7ff72] transition-colors\">\n                </div>\n                <div class=\"relative\">\n                    <select class=\"w-full bg-[#0a0a0a] border border-white/10 rounded-xl px-5 py-4 text-lg text-gray-400 appearance-none focus:outline-none focus:border-[#e7ff72] transition-colors cursor-pointer\">\n                        <option value=\"\" disabled=\"\" selected=\"\">Select Coaching Type</option>\n                        <option value=\"in-person\">In-Person (Hong Kong)</option>\n                        <option value=\"online\">Online (Global)</option>\n                        <option value=\"nutrition\">Nutrition Only</option>\n                    </select>\n                    <i data-lucide=\"chevron-down\" stroke-width=\"1.5\" class=\"absolute right-5 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500 pointer-events-none\"></i>\n                </div>\n                <button type=\"button\" class=\"w-full bg-[#e7ff72] text-black font-semibold text-xl py-4 rounded-xl hover:bg-white transition-colors mt-4\">\n                    Submit Application\n                </button>\n            </form>\n        </div>\n    </section>\n\n    <!-- Footer -->\n    <footer class=\"border-t border-white/5 py-12 px-6 bg-[#0a0a0a]\">\n        <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6\">\n            <div class=\"flex items-center select-none\">\n                <div class=\"relative inline-block text-2xl tracking-tighter uppercase text-white/50\" style=\"font-family: Impact, sans-serif;\">\n                    AN<span class=\"relative inline-block\">D<span class=\"absolute top-1/2 left-[45%] -translate-x-1/2 -translate-y-[45%] text-[0.18em] text-white/50 tracking-normal whitespace-nowrap\" style=\"font-family: sans-serif;\">COACHING BY</span></span>Y\n                </div>\n            </div>\n            \n            <div class=\"flex gap-8 text-gray-500 text-lg font-medium\">\n                <a href=\"#\" class=\"hover:text-[#e7ff72] transition-colors\">Instagram</a>\n                <a href=\"#\" class=\"hover:text-[#e7ff72] transition-colors\">Terms</a>\n                <a href=\"#\" class=\"hover:text-[#e7ff72] transition-colors\">Privacy</a>\n            </div>\n            \n            <p class=\"text-gray-600 text-sm font-medium\">\n                © 2024 Coaching by Andy. All rights reserved.\n            </p>\n        </div>\n    </footer>\n\n    <script>\n        lucide.createIcons();\n    </script>\n\n</body></html>","language":"html","username":"10c350c3-da28-4e2f-8fbd-606730dd6f8e","created_at":"2026-04-11T18:12:10.141017+00:00","views":239,"image_url":"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/preview-images/elite-fitness-76.png?t=1777366199874","forks":13,"private":false,"watermark":true,"featured":true,"share_source_code":true,"user_id":"10c350c3-da28-4e2f-8fbd-606730dd6f8e","category":"Mobile","updated_at":null,"tags":["Health","Services","Landing Page","Dark","Minimal","Clean","Animated"],"description":"A high-impact, dark-mode landing page template for fitness professionals and elite personal trainers to showcase services and collect client applications.","premium":false,"price":null,"purchase_url":null,"long_description":"## Overview\nThis is a premium, dark-themed **Landing Page Template** designed specifically for the fitness and coaching industry. It features a gritty, high-contrast aesthetic with neon accents, optimized for conversion and professional brand positioning.\n\n## Key Features\n- **Dynamic Hero Section:** High-impact typography with a clear call-to-action for immediate engagement.\n- **Credibility Marquee:** A dedicated credentials bar to highlight certifications, awards, and industry expertise.\n- **Service Tiers:** Grid layout showcasing 1-on-1 coaching, online global programs, and nutrition-specific protocols.\n- **Lead Generation Form:** A streamlined application form designed to capture qualified coaching leads.\n- **Responsive Design:** Fully mobile-optimized layout built with Tailwind CSS and Lucide icons.\n\n## Primary Use Case\nPerfect for elite personal trainers, online coaches, and bodybuilding professionals who want a **high-conversion platform** to showcase their transformation results and automate their intake process.","custom_domain":null,"favicon_light_url":null,"favicon_dark_url":null,"dns_verified":null,"dns_verified_at":null,"dns_a_record":null,"netlify_apex_exists":null,"netlify_www_exists":null,"netlify_verified_at":null,"custom_domain_added_at":null,"netlify_site_id":null,"umami_website_id":null,"umami_share_id":null,"analytics_enabled":false,"gtm_container_id":null,"remix_source":{},"credit_remix_source":false}]